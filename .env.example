# MaintainSMIP — environment variable NAMES only. NEVER put real values here.
#
# This file is committed on purpose so any developer or AI knows which env vars
# to wire up, without ever seeing a secret. Real values live only in:
#   - the Render dashboard (production), and
#   - a local .env file (gitignored) on a trusted machine, if needed.
#
# To run locally: copy to `.env`, fill in real values. `.env` is gitignored.

# --- Core app ---
APP_PASSWORD=            # master/legacy login password
APP_SECRET=             # session-signing HMAC secret (rotate = logs everyone out)
DATA_DIR=               # persistent data dir (Render: /var/data)
SEED_DEMO_DATA=false

# --- Backup ---
BACKUP_TOKEN=           # bearer token guarding the backup endpoint

# --- Email digest (Gmail SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=          # Gmail app password
SMTP_FROM=
NOTIFY_EMAIL_RECIPIENTS=

# --- Web Push (VAPID) ---
VAPID_EMAIL=mailto:support@smiproperties.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- AvidXchange (parts/procurement, Phase 3 — not wired yet) ---
# The adapter reads these with NO hardcoded fallback (os.environ["..."]),
# so a real secret can never end up as a default in source.
AVID_BASE_URL=          # sandbox vs production base URL
AVID_TOKEN_URL=         # OAuth token endpoint
AVID_CLIENT_ID=
AVID_CLIENT_SECRET=
AVID_VENDOR_DEFAULT=    # optional default vendor ref
